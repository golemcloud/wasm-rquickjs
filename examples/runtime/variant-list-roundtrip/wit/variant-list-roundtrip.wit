package quickjs:variant-list-roundtrip;

interface api {
  variant item {
    empty,
    number(u32),
    label(string),
  }

  record payload {
    items: list<item>,
  }

  variant envelope {
    none,
    batch(payload),
    direct(list<item>),
  }

  enum color {
    red,
    green,
    blue,
  }

  roundtrip-items: func(items: list<item>) -> list<item>;
  roundtrip-payload: func(payload: payload) -> payload;
  roundtrip-envelope: func(envelope: envelope) -> envelope;
  roundtrip-number: func(value: u32) -> u32;
  roundtrip-results: func(items: list<result<u32, string>>) -> list<result<u32, string>>;
  roundtrip-options: func(items: list<option<u32>>) -> list<option<u32>>;
  roundtrip-colors: func(items: list<color>) -> list<color>;
}

world variant-list-roundtrip {
  export api;
}
