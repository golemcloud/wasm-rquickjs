{
  // Node.js version these tests were vendored from
  "nodeVersion": "22.14.0",

  // Tests listed here are expected to pass.
  // Each key is a path relative to the suite/ directory.
  // Value is an object with optional configuration:
  //   "skip": true        - skip this test (with optional "reason")
  //   "flaky": true       - retry up to 3 times before failing
  //   "reason": "..."     - explanation for skip/flaky marking
  //
  // Only tests listed here will be run by the test harness.
  // Unlisted tests are ignored (not run, not reported).

  "tests": {
    // === node:path tests ===
    // Pure string operations, no I/O — highest likelihood of passing
    "parallel/test-path-basename.js": {
      "skip": true,
      "reason": "win32 basename not fully implemented; __filename assertion depends on path layout"
    },
    "parallel/test-path-dirname.js": {
      "skip": true,
      "reason": "__filename assertion expects test/parallel suffix"
    },
    "parallel/test-path-extname.js": {
      "skip": true,
      "reason": "win32 extname not fully implemented"
    },
    "parallel/test-path-join.js": {
      "skip": true,
      "reason": "win32 join not fully implemented"
    },
    "parallel/test-path-isabsolute.js": {
      "skip": true,
      "reason": "win32 isAbsolute not fully implemented"
    },
    "parallel/test-path-normalize.js": {
      "skip": true,
      "reason": "win32 normalize not fully implemented"
    },
    "parallel/test-path-parse-format.js": {
      "skip": true,
      "reason": "win32 parse/format not fully implemented"
    },
    "parallel/test-path-relative.js": {
      "skip": true,
      "reason": "win32 relative not fully implemented"
    },
    "parallel/test-path-resolve.js": {
      "skip": true,
      "reason": "requires ../common/fixtures module"
    },
    "parallel/test-path-zero-length-strings.js": {}
  }
}
