{
  // Node.js version these tests were vendored from
  "nodeVersion": "22.14.0",

  // Tests listed here are expected to pass.
  // Each key is a path relative to the suite/ directory.
  // Value is an object with optional configuration:
  //   "skip": true        - skip this test (with optional "reason")
  //   "flaky": true       - retry up to 3 times before failing
  //   "reason": "..."     - explanation for skip/flaky marking
  //
  // Only tests listed here will be run by the test harness.
  // Unlisted tests are ignored (not run, not reported).

  "tests": {
    // === node:path tests ===
    // Pure string operations, no I/O — highest likelihood of passing
    "parallel/test-path-basename.js": {
      "skip": true,
      "reason": "win32 basename not fully implemented; __filename assertion depends on path layout"
    },
    "parallel/test-path-dirname.js": {
      "skip": true,
      "reason": "__filename assertion expects test/parallel suffix"
    },
    "parallel/test-path-extname.js": {
      "skip": true,
      "reason": "win32 extname not fully implemented"
    },
    "parallel/test-path-join.js": {
      "skip": true,
      "reason": "win32 join not fully implemented"
    },
    "parallel/test-path-isabsolute.js": {
      "skip": true,
      "reason": "win32 isAbsolute not fully implemented"
    },
    "parallel/test-path-normalize.js": {
      "skip": true,
      "reason": "win32 normalize not fully implemented"
    },
    "parallel/test-path-parse-format.js": {
      "skip": true,
      "reason": "win32 parse/format not fully implemented"
    },
    "parallel/test-path-relative.js": {
      "skip": true,
      "reason": "win32 relative not fully implemented"
    },
    "parallel/test-path-resolve.js": {
      "skip": true,
      "reason": "requires ../common/fixtures module"
    },
    "parallel/test-path-zero-length-strings.js": {},

    // === node:assert tests ===
    "parallel/test-assert.js": {
      "skip": true,
      "reason": "requires source-code inspection (reading call-site expressions for assert.ok falsy messages) which is not available in QuickJS/WASM"
    },
    "parallel/test-assert-async.js": {},
    "parallel/test-assert-builtins-not-read-from-filesystem.js": {
      "skip": true,
      "reason": "requires child_process.spawnSync which is not available in WASM"
    },
    "parallel/test-assert-calltracker-calls.js": {},
    "parallel/test-assert-calltracker-getCalls.js": {},
    "parallel/test-assert-calltracker-report.js": {},
    "parallel/test-assert-calltracker-verify.js": {},
    "parallel/test-assert-checktag.js": {
      "skip": true,
      "reason": "QuickJS globalThis/process lack V8 internal type tags; notDeepEqual cannot distinguish faked copies"
    },
    "parallel/test-assert-deep-with-error.js": {},
    "parallel/test-assert-deep.js": {},
    "parallel/test-assert-esm-cjs-message-verify.js": {
      "skip": true,
      "reason": "requires process spawning (spawnPromisified) which is not available in WASM"
    },
    "parallel/test-assert-fail-deprecation.js": {},
    "parallel/test-assert-fail.js": {},
    "parallel/test-assert-first-line.js": {
      "skip": true,
      "reason": "requires loading fixture files from filesystem which is not available in WASM"
    },
    "parallel/test-assert-if-error.js": {},
    "parallel/test-assert-objects.js": {
      "skip": true,
      "reason": "partialDeepStrictEqual tests cause WASM stack overflow due to deep recursion exceeding WASM stack limits"
    },
    "parallel/test-assert-typedarray-deepequal.js": {},

    // === node:querystring tests ===
    "parallel/test-querystring.js": {},
    "parallel/test-querystring-escape.js": {},
    "parallel/test-querystring-multichar-separator.js": {},
    "parallel/test-querystring-maxKeys-non-finite.js": {},

    // === node:url tests ===
    "parallel/test-url-fileurltopath.js": {},
    "parallel/test-url-pathtofileurl.js": {},
    "parallel/test-url-urltooptions.js": {},
    "parallel/test-url-format-whatwg.js": {},
    "parallel/test-url-format-invalid-input.js": {},
    "parallel/test-url-domain-ascii-unicode.js": {
      "skip": true,
      "reason": "requires ICU/punycode support (hasIntl)"
    },
    "parallel/test-url-format.js": {
      "skip": true,
      "reason": "requires full legacy url.format with complex edge cases and hasIntl"
    },
    "parallel/test-url-parse-format.js": {
      "skip": true,
      "reason": "requires full legacy url.parse with complex edge cases and hasIntl"
    },
    "parallel/test-url-parse-invalid-input.js": {
      "skip": true,
      "reason": "requires ERR_INVALID_URL error code and process.execPath/spawnPromisified"
    },
    "parallel/test-url-parse-query.js": {
      "skip": true,
      "reason": "requires full legacy url.parse with query string parsing and Url constructor"
    },
    "parallel/test-url-relative.js": {
      "skip": true,
      "reason": "requires full legacy url.resolveObject with complex edge cases"
    },

    // === node:util tests ===
    "parallel/test-util-callbackify.js": {
      "skip": true,
      "reason": "requires child_process.execFile and common/fixtures for uncaught-exception tests"
    },
    "parallel/test-util-deprecate-invalid-code.js": {
      "skip": true,
      "reason": "requires ERR_INVALID_ARG_TYPE error code from util.deprecate"
    },
    "parallel/test-util-deprecate.js": {
      "skip": true,
      "reason": "requires process.on('warning') and process.on('exit') hooks"
    },
    "parallel/test-util-emit-experimental-warning.js": {
      "skip": true,
      "reason": "requires internal/util and process.on('warning')"
    },
    "parallel/test-util-format.js": {
      "skip": true,
      "reason": "requires internalBinding('util').getConstructorName to recover class names from null-prototype objects"
    },
    "parallel/test-util-getcallsite.js": {
      "skip": true,
      "reason": "requires util.getCallSite which is not implemented"
    },
    "parallel/test-util-getcallsites.js": {
      "skip": true,
      "reason": "requires child_process.spawnSync, common/fixtures, and util.getCallSites"
    },
    "parallel/test-util-inherits.js": {},
    "parallel/test-util-inspect-getters-accessing-this.js": {},
    "parallel/test-util-inspect-long-running.js": {},
    "parallel/test-util-inspect-namespace.js": {
      "skip": true,
      "reason": "requires experimental vm.SourceTextModule"
    },
    "parallel/test-util-inspect-proxy.js": {
      "skip": true,
      "reason": "requires --expose-internals and internalBinding('util')"
    },
    "parallel/test-util-inspect.js": {
      "skip": true,
      "reason": "requires --expose-internals and internal/errors"
    },
    "parallel/test-util-internal.js": {
      "skip": true,
      "reason": "requires --expose-internals and internalBinding('util')"
    },
    "parallel/test-util-isDeepStrictEqual.js": {},
    "parallel/test-util-log.js": {
      "skip": true,
      "reason": "requires common/hijackstdio and process.stdout.writable"
    },
    "parallel/test-util-parse-env.js": {
      "skip": true,
      "reason": "requires util.parseEnv and common/fixtures"
    },
    "parallel/test-util-primordial-monkeypatching.js": {},
    "parallel/test-util-promisify.js": {
      "skip": true,
      "reason": "requires --expose-internals (internal/util customPromisifyArgs)"
    },
    "parallel/test-util-sigint-watchdog.js": {
      "skip": true,
      "reason": "requires --expose-internals and internalBinding('contextify')"
    },
    "parallel/test-util-sleep.js": {
      "skip": true,
      "reason": "requires internal/util sleep function"
    },
    "parallel/test-util-stripvtcontrolcharacters.js": {
      "skip": true,
      "reason": "requires util.stripVTControlCharacters which is not implemented"
    },
    "parallel/test-util-styletext.js": {
      "skip": true,
      "reason": "requires util.styleText and node:tty WriteStream"
    },
    "parallel/test-util-text-decoder.js": {},
    "parallel/test-util-types-exists.js": {
      "skip": true,
      "reason": "requires util/types subpath module resolution"
    },
    "parallel/test-util-types.js": {
      "skip": true,
      "reason": "requires --expose-internals, internalBinding, and vm.SourceTextModule"
    },
    "parallel/test-util.js": {
      "skip": true,
      "reason": "requires --expose-internals and internal/errors"
    }
  }
}
