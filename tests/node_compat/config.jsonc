{
  // Node.js version these tests were vendored from
  "nodeVersion": "22.14.0",

  // Tests listed here are included in the compatibility inventory.
  // Each key is a path relative to the suite/ directory.
  // Value is an object with optional configuration:
  //   "category": "..."   - classification used by both the runner and report generator:
  //                         "runnable"          - public API test expected to pass
  //                         "known-gap"         - public API is missing but in scope
  //                         "wasi-impossible"   - cannot be provided on WASI P2
  //                         "engine-difference" - V8 behavior QuickJS cannot reasonably mirror
  //                         "node-internals"    - tests Node.js internals/implementation details
  //                         "unevaluated"       - not triaged yet; excluded from percentages
  //   "flaky": true       - retry up to 3 times before failing
  //   "reason": "..."     - explanation for skip/flaky/impossible marking
  //
  // Only tests listed here will be run by the test harness.
  // Unlisted tests are ignored (not run, not reported).

  "tests": {
