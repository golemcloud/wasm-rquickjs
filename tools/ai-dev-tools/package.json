{
  "name": "ai-dev-tools",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered development tools for wasm-rquickjs",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "fix": "tsx src/cli.ts fix",
    "lint": "eslint src/",
