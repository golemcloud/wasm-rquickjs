    "@types/node": "^22.0.0",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.1"
  },
  "dependencies": {
    "@sourcegraph/amp-sdk": "^0.1.0-20260223122441-g31e6594",
    "jsonc-parser": "^3.3.1",
    "log-update": "^7.1.0",
    "simple-git": "^3.32.2"
  }
}
